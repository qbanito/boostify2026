rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    match /image_galleries/{galleryId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
    
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(userId);
    }
    
    match /artist_profiles/{profileId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /shows/{showId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /products/{productId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /artist_music/{songId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.artistId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.artistId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.artistId == request.auth.uid;
    }
    
    match /Video_Director_AI/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /AI_Music_Composer/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /Strategic_Marketing_AI/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /Social_Media_AI/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /Merchandise_Designer_AI/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /Manager_AI/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.createdBy;
    }

    match /users/{userId}/metrics/{metricId} {
      allow read, write: if isOwner(userId);
    }

    match /course_progress/{progressId} {
      allow read: if isAuthenticated() && progressId.matches(request.auth.uid + '_.*');
      allow create: if isAuthenticated() && progressId.matches(request.auth.uid + '_.*');
      allow update: if isAuthenticated() && progressId.matches(request.auth.uid + '_.*') &&
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['completedLessons', 'completedExams', 'currentLesson', 
                     'lastAccessedAt', 'generatedImages', 'lessonImages',
                     'timeSpent', 'lastCompletedAt', 'lessonContents',
                     'examScores']) ||
          !exists(/databases/$(database)/documents/course_progress/$(progressId))
        );
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /songs/{songId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /strategies/{strategyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /investors/{investorId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /technical_rider/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /requirements/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /budget/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /logistics/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /hiring/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /calendar/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /ai_tools/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /production_projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /production_phases/{phaseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        request.resource.data.collaborators[request.auth.uid] == true
      );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /production_tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.assignedTo == request.auth.uid ||
        request.resource.data.collaborators[request.auth.uid] == true
      );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    match /production_notes/{noteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }
    
    match /version_control/{versionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        request.resource.data.collaborators[request.auth.uid] == true
      );
      allow delete: if isAuthenticated() && resource.data.uploadedBy == request.auth.uid;
    }
    
    match /version_feedback/{feedbackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }
    
    match /production_files/{fileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        request.resource.data.collaborators[request.auth.uid] == true
      );
      allow delete: if isAuthenticated() && resource.data.uploadedBy == request.auth.uid;
    }
    
    match /musicVideoProjects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        !resource.data.userId || 
        resource.data.userId == request.auth.uid
      );
      allow delete: if isAuthenticated() && (
        !resource.data.userId || 
        resource.data.userId == request.auth.uid
      );
    }
    
    // ── WhatsApp Artist Command Center ───────────────────────────────────────
    // All WhatsApp data lives under artists/{artistId}/whatsapp* subcollections
    // and is ONLY ever read/written by the Boostify backend via the Admin SDK
    // (which bypasses these rules). Direct client access is denied so OpenWA
    // sessions, tokens, contacts and messages can never be touched from the
    // browser. Routes: /api/whatsapp/*.
    match /artists/{artistId}/whatsappSessions/{sessionId} { allow read, write: if false; }
    match /artists/{artistId}/whatsappContacts/{contactId} { allow read, write: if false; }
    match /artists/{artistId}/whatsappMessages/{messageId} { allow read, write: if false; }
    match /artists/{artistId}/whatsappCampaigns/{campaignId} { allow read, write: if false; }
    match /artists/{artistId}/aiCommands/{commandId} { allow read, write: if false; }
    match /artists/{artistId}/whatsappSales/{saleId} { allow read, write: if false; }
    match /artists/{artistId}/whatsappAuditLog/{logId} { allow read, write: if false; }

    // ── Telegram Artist Command Center ───────────────────────────────────────
    // All Telegram data lives under artists/{artistId}/telegram* subcollections
    // and is ONLY ever read/written by the Boostify backend via the Admin SDK
    // (which bypasses these rules). Direct client access is denied so bot
    // tokens, subscribers and messages can never be touched from the browser.
    // Routes: /api/telegram/*.
    match /artists/{artistId}/telegramBots/{botId} { allow read, write: if false; }
    match /artists/{artistId}/telegramUsers/{userId} { allow read, write: if false; }
    match /artists/{artistId}/telegramMessages/{messageId} { allow read, write: if false; }
    match /artists/{artistId}/telegramCampaigns/{campaignId} { allow read, write: if false; }
    match /artists/{artistId}/telegramCommunities/{communityId} { allow read, write: if false; }
    match /artists/{artistId}/telegramAICommands/{commandId} { allow read, write: if false; }
    match /artists/{artistId}/telegramSales/{saleId} { allow read, write: if false; }
    match /artists/{artistId}/telegramAuditLog/{logId} { allow read, write: if false; }

    // Reddit Artist Intelligence Center — READ-ONLY market intelligence written
    // ONLY by the Boostify backend (Admin SDK). No tokens are stored (app-level
    // OAuth), but config/intel/reports are denied to direct client access so
    // strategy data and audit trails stay server-authoritative. Routes: /api/reddit/*.
    match /artists/{artistId}/redditConfig/{docId} { allow read, write: if false; }
    match /artists/{artistId}/redditIntel/{docId} { allow read, write: if false; }
    match /artists/{artistId}/redditReports/{reportId} { allow read, write: if false; }
    match /artists/{artistId}/redditAuditLog/{logId} { allow read, write: if false; }

    // Discord Fan Nation — community hub written ONLY by the Boostify backend
    // (Admin SDK). Per-artist OAuth tokens are AES-256-GCM encrypted; bot token
    // is app-level and never stored here. All client access denied so member
    // data, gating rules and audit trails stay server-authoritative.
    // Routes: /api/discord/*.
    match /artists/{artistId}/discordGuilds/{guildId} { allow read, write: if false; }
    match /artists/{artistId}/discordConfig/{docId} { allow read, write: if false; }
    match /artists/{artistId}/discordChannels/{channelId} { allow read, write: if false; }
    match /artists/{artistId}/discordRoles/{roleId} { allow read, write: if false; }
    match /artists/{artistId}/discordMembers/{memberId} { allow read, write: if false; }
    match /artists/{artistId}/discordCampaigns/{campaignId} { allow read, write: if false; }
    match /artists/{artistId}/discordEvents/{eventId} { allow read, write: if false; }
    match /artists/{artistId}/discordRewards/{rewardId} { allow read, write: if false; }
    match /artists/{artistId}/discordAICommands/{cmdId} { allow read, write: if false; }
    match /artists/{artistId}/discordModeration/{modId} { allow read, write: if false; }
    match /artists/{artistId}/discordAuditLog/{logId} { allow read, write: if false; }
    
    match /{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}

