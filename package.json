  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "start": "node dist/server/index.js",
    "start:worker": "node dist/server/worker.js",
    "worker:dev": "npx tsx watch server/worker.ts",
    "build": "node build-for-deploy.js",
    "server:dev": "npx tsx watch --clear-screen=false --ignore=\"uploads/**\" --ignore=\"attached_assets/**\" --ignore=\"dist/**\" --ignore=\"client/**\" --ignore=\".venv/**\" --ignore=\"logs/**\" --ignore=\"**/*.log\" --ignore=\"**/*.json\" --ignore=\"node_modules/**\" server/index.ts",
    "client:dev": "vite --config vite.config.ts",
    "db:migrate": "npx drizzle-kit push",
    "build:deploy": "node build-for-deploy.js",
    "desktop:dev": "cd desktop && npm run dev",
    "desktop:build": "cd desktop && npm run build",
    "desktop:dist": "cd desktop && npm run dist",
    "desktop:dist:win": "cd desktop && npm run dist:win",
    "desktop:dist:mac": "cd desktop && npm run dist:mac",
    "timeline:dev": "cd desktop-timeline && npm run dev",
    "timeline:build": "cd desktop-timeline && npm run build",
    "timeline:dist": "cd desktop-timeline && npm run dist",
    "timeline:dist:win": "cd desktop-timeline && npm run dist:win",
    "timeline:dist:mac": "cd desktop-timeline && npm run dist:mac",
    "outreach:daily": "npx tsx scripts/investor-outreach.ts daily",
    "outreach:quick": "npx tsx scripts/investor-outreach.ts quick",
    "outreach:collect": "npx tsx scripts/investor-outreach.ts collect",
    "outreach:stats": "npx tsx scripts/investor-outreach.ts stats",
    "remotion:studio": "npx remotion studio remotion/index.ts",
    "remotion:render": "npx remotion render remotion/index.ts MusicVideo out/music-video.mp4",
    "remotion:render:horizontal": "npx remotion render remotion/index.ts MusicVideoHorizontal out/music-video-horizontal.mp4",
    "remotion:render:square": "npx remotion render remotion/index.ts MusicVideoSquare out/music-video-square.mp4",
    "mcp:stdio": "npx tsx server/mcp/stdio-transport.ts"
  },
