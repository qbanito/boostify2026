{
  "manifest_version": 3,
  "name": "Boostify Spotify Sync",
  "version": "1.0.0",
  "description": "Sync Spotify with Boostify AI: playlist pitching, SEO optimization, curator discovery & analytics.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "tabs",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "https://open.spotify.com/*",
    "https://api.spotify.com/*",
    "https://boostifymusic.com/*",
    "http://localhost:5000/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["src/content/spotify-main.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "https://boostifymusic.com/*",
      "http://localhost:5000/*"
    ]
  }
}
