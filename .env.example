# Clerk (Frontend - Vite)
VITE_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Clerk (Backend)
CLERK_SECRET_KEY=YOUR_SECRET_KEY
CLERK_JWT_ISSUER=https://clerk.YOUR_DOMAIN.dev

# Firebase Admin (Backend)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project-id.iam.gserviceaccount.com
# Note: Preserve literal \n in the private key; backend will replace with real newlines
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_LINES\n-----END PRIVATE KEY-----\n
# Optional (old Firebase client config if you still have analytics-only needs)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Database configuration (Postgres/Neon)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
PGDATABASE=your_postgres_database
PGHOST=your_postgres_host
PGPORT=5432
PGUSER=your_postgres_user
PGPASSWORD=your_postgres_password

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=your_stripe_public_key
TESTING_VITE_STRIPE_PUBLIC_KEY=pk_test_your_key
TESTING_STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET_DEV=whsec_your_secret

# Apify Configuration
APIFY_API_KEY=your_apify_api_key
VITE_APIFY_API_KEY=your_apify_api_key

# OpenAI / AI providers
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_KEY2=your_openai_api_key
VITE_OPENAI_API_KEY=your_openai_api_key
VITE_MISTRAL_API_KEY=your_mistral_api_key
# OpenRouter — free model cascade fallback (llama-3.3-70b, gemma-3-27b, deepseek-r1, mistral-7b, qwen3-235b)
# Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
AI_INTEGRATIONS_GEMINI_BASE_URL=http://localhost:1106/modelfarm/gemini
AI_INTEGRATIONS_GEMINI_API_KEY=_DUMMY_API_KEY_

# Gemini API Keys (para generación de imágenes y video - fallback de FAL)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEY2=your_secondary_gemini_api_key
GEMINI_IMAGE_API_KEY=your_gemini_image_api_key  # API key específica para Imagen 3 y Veo 2

# YouTube / Google
YOUTUBE_API_KEY=your_youtube_key
GOOGLE_API_KEY2=your_google_key
GOOGLE_API_KEY3=your_google_key

# WalletConnect / Web3 (Required for MetaMask connection)
# Get your Project ID from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# FAL / Freepik / Luma / Heygen
FAL_API_KEY=your_fal_key
FAL_KEY_BACKUP=your_fal_backup
VITE_FAL_API_KEY=your_fal_key
FREEPIK_API_KEY=your_freepik_key
VITE_FREEPIK_KEY=your_freepik_key
VITE_LUMA_API_KEY=your_luma_key
VITE_HEYGEN_API_KEY=your_heygen_key

# HuggingFace (FHDR Uncensored model — Exclusive Content AI Studio)
HUGGINGFACE_TOKEN=hf_your_token_here
# HF Inference Endpoint for FHDR (optional, deploy at https://ui.endpoints.huggingface.co)
# HF_FHDR_ENDPOINT_URL=https://your-endpoint.aws.endpoints.huggingface.cloud

# Zuno / Kits AI / PIAPI / Revocalize
ZUNO_API_KEY=your_zuno_key
KITS_AI_API_KEY=your_kits_ai_key
PIAPI_API_KEY=your_piapi_key
VITE_PIAPI_API_KEY=your_piapi_key
REVOCALIZE_API_KEY=your_revocalize_key

# App Configuration
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
PUBLIC_URL=
SESSION_SECRET=change_me_strong_secret

# PM2 Configuration (For Production)
PM2_INSTANCES=1         # Number of instances to launch (use 0 for max cores)
PM2_EXEC_MODE=cluster   # Execution mode: 'fork' or 'cluster'
PM2_WATCH=false         # Watch for file changes (set to false in production)

# OpenClaw Configuration
OPENCLAW_ENABLED=false
OPENCLAW_PORT=18789
OPENCLAW_BIND=127.0.0.1
OPENCLAW_MODEL=anthropic/claude-opus-4-6
OPENCLAW_INTERNAL_TOKEN=change_me_to_a_strong_random_token
OPENCLAW_GATEWAY_PASSWORD=change_me_strong_password
PM2_MAX_MEMORY=512      # Restart app if it exceeds this memory limit (MB)

# Resend Email Service
RESEND_API_KEY=re_xxxxxxxx  # Resend API key for email notifications
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxx  # Resend webhook secret for signature verification

# Replit Configuration (deprecated — migrating to Render)
REPLIT_PORT=
REPLIT_IDENTITY=
REPL_SLUG=

# Security Settings
CORS_ORIGIN=*           # Use specific domain in production, e.g. https://your-domain.com
SESSION_SECRET=         # Strong random string for session encryption
COOKIE_SECURE=true      # Set to true in production (requires HTTPS)
COOKIE_SAME_SITE=lax    # Cookie same-site policy (lax, strict, or none)

# Native Wallet (Apple Wallet .pkpass signed in backend)
PUBLIC_APP_URL=http://localhost:3000
APPLE_PASS_TYPE_IDENTIFIER=pass.com.yourcompany.boostify.artist
APPLE_TEAM_IDENTIFIER=YOUR_APPLE_TEAM_ID
APPLE_ORGANIZATION_NAME=Boostify Music
APPLE_WALLET_CERT_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
APPLE_WALLET_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
APPLE_WALLET_KEY_PASSPHRASE=
APPLE_WWDR_CERT_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
APPLE_PASS_BRAND_COLOR=#ff7a00

# Native Wallet (Google Wallet Save URL JWT signed in backend)
GOOGLE_WALLET_ISSUER_ID=3388000000021234567
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=wallet-signer@your-project.iam.gserviceaccount.com
GOOGLE_WALLET_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
GOOGLE_WALLET_CLASS_SUFFIX=boostify_artist_card
# --- AMAZON PRODUCT ADVERTISING API 5 (Cultural Storefront) ---
# OPTIONAL — only needed for the AUTO mode (AI-curated picks).
# Manual mode (artists pasting ASINs in Settings) works WITHOUT these vars.
#
# Sign up at https://affiliate-program.amazon.com/ then create credentials at:
# https://webservices.amazon.com/paapi5/documentation/register-for-pa-api.html
# Tag suffix determines marketplace: -20 = US, -21 = UK, -05 = FR, -15 = ES, -22 = JP, etc.
PAAPI_ACCESS_KEY=
PAAPI_SECRET_KEY=
PAAPI_PARTNER_TAG=                  # default platform tag (fallback when artist has no own tag), e.g. boostify-20 for US
# Defaults below are for amazon.com (US). For UK use webservices.amazon.co.uk / eu-west-1 / www.amazon.co.uk
PAAPI_HOST=webservices.amazon.com
PAAPI_REGION=us-east-1
PAAPI_MARKETPLACE=www.amazon.com

# --- WHATSAPP ARTIST COMMAND CENTER (OpenWA gateway) ---
# Run OpenWA as a SEPARATE service (whatsapp-gateway-service, Docker or Node)
# that exposes a thin REST API. Boostify only talks to it through this adapter.
# ⚠️ OpenWA is NOT the official Meta API — use for support/concierge/controlled
# automations only, never spam. Migration to WhatsApp Business Cloud API planned.
#
# If OPENWA_BASE_URL is left empty the module runs in SIMULATION mode (no real
# messages sent) so the dashboard is fully usable in local dev.
OPENWA_BASE_URL=            # e.g. http://localhost:8002  (empty = simulation mode)
OPENWA_API_KEY=            # shared secret sent as `api_key` header + webhook `x-openwa-token`
BOOSTIFY_API_URL=http://localhost:5001   # so the gateway can call back into Boostify webhooks (dev runs on 5001)
# BTF token + Stripe are reused from the existing Economic Engine / payments config:
#   BTF_TOKEN_CONTRACT, STRIPE_SECRET_KEY (already defined above)

# --- TELEGRAM ARTIST COMMAND CENTER (Bot API gateway) ---
# Token-based: each artist pastes their own @BotFather bot token in the UI; the
# backend validates it (getMe), AES-encrypts it at rest and registers a per-artist
# webhook. Enter token "demo" in the UI to run the module in SIMULATION mode.
# TELEGRAM_BOT_API_BASE_URL is OPTIONAL — only set it if you self-host a Telegram
# Bot API server (telegram-gateway-service); leave empty to use api.telegram.org.
TELEGRAM_BOT_API_BASE_URL=   # e.g. http://localhost:8081  (empty = https://api.telegram.org)
TELEGRAM_WEBHOOK_SECRET=     # shared secret echoed by Telegram as `x-telegram-bot-api-secret-token`
TELEGRAM_TOKEN_ENC_KEY=      # 32+ char secret used to AES-256-GCM encrypt artist bot tokens at rest

# --- REDDIT ARTIST INTELLIGENCE CENTER (read-only market intelligence) ---
# App-level OAuth2 (client_credentials grant) — artists connect nothing; Boostify
# queries Reddit on their behalf to discover fans, detect trends, analyze
# communities/competitors and surface viral opportunities. This module NEVER
# posts, comments or votes. Create a "script"/"web app" at
# https://www.reddit.com/prefs/apps to obtain the id/secret. Leave EMPTY to run
# the module in SIMULATION mode (deterministic demo data, no network).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:boostify-music-intelligence:v1.0 (by /u/your_reddit_user)

# --- DISCORD FAN NATION (community hub: OAuth2 + bot, roles, token gate, AI) ---
# Premium Discord community module: connect a server, run the setup wizard
# (channels + roles), token-gate VIP access with $BTF, run campaigns/events,
# reward fans and moderate with AI. The BOT TOKEN is an app-level secret used
# ONLY by the backend — never exposed to the browser. Per-artist OAuth tokens
# are AES-256-GCM encrypted at rest. Create an application + bot at
# https://discord.com/developers/applications. Leave EMPTY to run the module in
# SIMULATION mode (deterministic demo data, no network calls).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_REDIRECT_URI=https://your-app-domain.com/api/discord/oauth/callback
# Optional dedicated 32-byte key for encrypting OAuth tokens (falls back to
# DISCORD_CLIENT_SECRET if unset).
DISCORD_TOKEN_ENC_KEY=